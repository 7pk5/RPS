<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <!-- ─── Header ─── -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✊ ✋ ✌️ RPS Arena"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subtitle"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="4dp" />

        <!-- ─── Scoreboard ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center">

            <!-- You Score -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_you"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/tvHumanScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_win" />
            </LinearLayout>

            <!-- Round -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_round"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/tvRoundNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <!-- AI Score -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_ai"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/tvAiScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_lose" />
            </LinearLayout>
        </LinearLayout>

        <!-- ─── Camera Preview ─── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="280dp"
            android:background="@drawable/bg_camera_viewport"
            android:clipToOutline="true"
            android:layout_marginBottom="12dp">

            <androidx.camera.view.PreviewView
                android:id="@+id/previewView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Gesture Badge -->
            <LinearLayout
                android:id="@+id/gestureBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="12dp"
                android:background="@drawable/bg_glass_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvGestureIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤚"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvGestureLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/waiting"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- Countdown Overlay -->
            <FrameLayout
                android:id="@+id/countdownOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#D90A0E17"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvAiHand"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✊"
                        android:textSize="72sp" />

                    <TextView
                        android:id="@+id/tvCountdown"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_indigo"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </FrameLayout>
        </FrameLayout>

        <!-- ─── Controls ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnPlay"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_gradient_button"
                android:text="🎮  Play Round"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:enabled="false" />

            <Button
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_secondary_button"
                android:text="🔄  Reset"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- ─── Result Panel ─── -->
        <LinearLayout
            android:id="@+id/resultPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/round_result"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp" />

            <!-- Moves Row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Your Move -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvResultHumanEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✊"
                        android:textSize="40sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_you"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvResultHumanGesture"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rock"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />
                </LinearLayout>

                <!-- VS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/vs"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_muted"
                    android:layout_marginHorizontal="24dp" />

                <!-- AI Move -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvResultAiEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✋"
                        android:textSize="40sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_ai"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvResultAiGesture"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Paper"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Outcome -->
            <TextView
                android:id="@+id/tvResultOutcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Draw!"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/color_draw"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- ─── Match History ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/match_history"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvLogEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_rounds"
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:gravity="center" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />
        </LinearLayout>

        <!-- ─── Footer ─── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Powered by Parimal Kalpande"
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:layout_marginBottom="12dp" />

    </LinearLayout>
</ScrollView>
