<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient">

    <!-- ─── Left Side: Camera Preview (55% width) ─── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/leftPanel"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintWidth_percent="0.55"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:padding="14dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Camera feed with rounded corners + candy-pink border -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_camera_viewport"
                android:clipToOutline="true">

                <androidx.camera.view.PreviewView
                    android:id="@+id/previewView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>

            <!-- Camera Border Flash overlay -->
            <View
                android:id="@+id/cameraBorderFlash"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_camera_border_flash"
                android:alpha="0" />

            <!-- Non-blocking camera hint (always visible, informational only) -->
            <TextView
                android:id="@+id/tvCameraHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="10dp"
                android:text="@string/camera_hint"
                android:textColor="#BBFFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="#44000000"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp" />

            <!-- Gesture Badge -->
            <LinearLayout
                android:id="@+id/gestureBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="12dp"
                android:background="@drawable/bg_glass_badge"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvGestureIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤚"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvGestureLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/waiting"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- Countdown Overlay -->
            <FrameLayout
                android:id="@+id/countdownOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#E61E1B4B"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvAiHand"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✊"
                        android:textSize="72sp" />

                    <TextView
                        android:id="@+id/tvCountdown"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="44sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_yellow"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/tvHoldGesture"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/hold_gesture"
                        android:textSize="14sp"
                        android:textColor="@color/accent_yellow"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"
                        android:alpha="0.9" />
                </LinearLayout>
            </FrameLayout>
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ─── Right Side: Controls and Scoreboard ─── -->
    <ScrollView
        android:id="@+id/rightPanel"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintStart_toEndOf="@id/leftPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal">

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✊ ✋ ✌️ RPS Arena!"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/subtitle"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="14dp"
                android:layout_marginTop="2dp" />

            <!-- Controls -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="14dp">

                <Button
                    android:id="@+id/btnPlay"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_gradient_button_disabled"
                    android:text="@string/starting_camera"
                    android:textColor="#88FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:stateListAnimator="@null"
                    android:enabled="false" />

                <Button
                    android:id="@+id/btnReset"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_secondary_button"
                    android:text="🔄 Reset"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- Scoreboard -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:gravity="center">

                <!-- Your Score -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_you"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold" />
                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_score_badge">
                        <TextView
                            android:id="@+id/tvHumanScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="0"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_win" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Round -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_round"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvRoundNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="1"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

                <!-- AI Score -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_ai"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold" />
                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_score_badge">
                        <TextView
                            android:id="@+id/tvAiScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="0"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_lose" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Result Panel -->
            <LinearLayout
                android:id="@+id/resultPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/round_result"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <!-- Your Move -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvResultHumanEmoji"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✊"
                            android:textSize="40sp" />
                        <TextView
                            android:id="@+id/tvResultHumanGesture"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rock"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/vs"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_muted"
                        android:layout_marginHorizontal="20dp" />

                    <!-- AI Move -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvResultAiEmoji"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✋"
                            android:textSize="40sp" />
                        <TextView
                            android:id="@+id/tvResultAiGesture"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Paper"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvResultOutcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Draw!"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_draw"
                    android:layout_marginTop="10dp" />
            </LinearLayout>

            <!-- Match History -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/match_history"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvLogEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/no_rounds"
                    android:textSize="13sp"
                    android:textColor="@color/text_muted"
                    android:gravity="center" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never" />
            </LinearLayout>

            <!-- Footer -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Powered by Parimal Kalpande"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
